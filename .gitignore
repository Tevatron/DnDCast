# ── Server config (contains hashed password + session secret) ──────────
config.json

# ── Live data files ─────────────────────────────────────────────────────
data/scenes.json
data/sessions.json
data/campaigns.json

# ── Media assets (large binary files, manage outside git) ──────────────
assets/images/*
assets/audio/*

# Keep directory placeholders
!assets/images/.gitkeep
!assets/audio/.gitkeep

# ── Session storage (persisted login state, never commit) ───────────────
sessions/

# ── Playwright test artifacts ────────────────────────────────────────────
playwright-report/
test-results/

# ── Dependencies ────────────────────────────────────────────────────────
node_modules/

# ── OS / editor noise ───────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
