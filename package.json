{
  "name": "dndcast",
  "version": "1.0.0",
  "description": "D&D session player with DM control, audio, and real-time cast sync.",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "setup": "node setup.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "vitest run && playwright test"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "multer": "^2.2.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^29.1.1",
    "supertest": "^7.2.2",
    "vitest": "^4.1.9"
  }
}
